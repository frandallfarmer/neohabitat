---
extends: default
rules:
  line-length:
    max: 240
    # SSH public keys and apt repository lines live on single lines and
    # are inherently long.
    ignore: |
      inventory/group_vars/all.yml
      roles/neohabitat/tasks/packages.yml
  truthy: disable
  comments-indentation: disable
  comments:
    min-spaces-from-content: 1
  braces:
    max-spaces-inside: 1
  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: true
