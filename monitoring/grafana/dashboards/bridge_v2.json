              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "bridge_v2_client_crashes_total",
          "legendFormat": "crashes",
          "refId": "A"
        }
