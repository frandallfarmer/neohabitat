        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "expr": "{container=~\".*bridge_v2.*\"} |= \"Client crash report\" | json",
          "legendFormat": "",
          "refId": "A"
        }
