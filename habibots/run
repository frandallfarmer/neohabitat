#!/bin/bash
# Launches all Habitat bots.

set -eo pipefail

trap 'kill %1; kill %2' SIGINT

HABITAT_HOST="${HABIBOTS_HOST-habitat.themade.org}"
HABITAT_PORT="${HABIBOTS_PORT-1337}"
CONNECTOR_REGION="${HABIBOTS_CONNECTOR_REGION-context-Downtown_5f}"
ELIZA_REGION="${HABIBOTS_ELIZA_REGION-context-Downtown_5f}"
GREETER1_REGION="${HABIBOTS_GREETER1_REGION-context-welcomecenterinthatch}"
HATCHERY_REGION="${HABIBOTS_HATCHERY_REGION-context-hatchery}"

#DO NOT PUT A BOGUS SLACK TOKEN HERE
SLACK_TOKEN="${HABIBOTS_SLACK_TOKEN-}"

DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"

while ! netcat -z ${HABITAT_HOST} ${HABITAT_PORT}; do
  sleep 10
done

sleep 10

cd ${DIR}

if [[ "${@}" = *"greeter1"* ]]; then
  echo 'Launching greeter1...'
  supervisor -w "${DIR}" -- bots/greeter.js \
    -g "${DIR}/assets/greeting.txt" \
    -s "${HABIBOTS_SLACK_TOKEN}" \
    -c "${GREETER1_REGION}" \
    -h "${HABITAT_HOST}" \
    -p "${HABITAT_PORT}" \
    -l "newavatars" \
    -u phil &
fi

if [[ "${@}" = *"connector"* ]]; then
  echo 'Launching connector...'
  supervisor -w "${DIR}" -- bots/connector.js \
    -c "${CONNECTOR_REGION}" \
    -h "${HABITAT_HOST}" \
    -p "${HABITAT_PORT}" \
    -u connectorbot &
fi

if [[ "${@}" = *"eliza"* ]]; then
  echo 'Launching eliza...'
  supervisor -w "${DIR}" -- bots/eliza.js \
    -c "${ELIZA_REGION}" \
    -h "${HABITAT_HOST}" \
    -p "${HABITAT_PORT}" \
    -u elizabot &
fi

if [[ "${@}" = *"walker"* ]]; then
  echo 'Launching walker...'
  supervisor --inspect -w "${DIR}" -- bots/walker.js \
    -c "${GREETER1_REGION}" \
    -h "${HABITAT_HOST}" \
    -p "${HABITAT_PORT}" \
    -u tonybanks
fi

if [[ "${@}" = *"protester"* ]]; then
  echo 'Launching protester...'
  supervisor -w "${DIR}" -- bots/protester.js \
    -c "${GREETER1_REGION}" \
    -h "${HABITAT_HOST}" \
    -p "${HABITAT_PORT}" \
    -u tonybanks &
fi

if [[ "${@}" = *"oracle"* ]]; then
  echo 'Launching oracle...'
  supervisor -w "${DIR}" -- bots/oracle.js \
    -c "${GREETER1_REGION}" \
    -h "${HABITAT_HOST}" \
    -p "${HABITAT_PORT}" \
    -s "${SLACK_TOKEN}" \
    -u devil &
fi

if [[ "${@}" = *"sage"* ]]; then
  if [[ -z "${ANTHROPIC_API_KEY}" ]]; then
    # No key, no launch. Skip silently — bots.env may not be deployed
    # yet, and we don't want supervisor to thrash a process that's just
    # going to exit. Re-deploy after writing the secret to bring sage up.
    echo 'Skipping sage (ANTHROPIC_API_KEY not set).'
  else
    echo 'Launching sage...'
    # Defaults via separate vars — embedding a default with an apostrophe
    # directly inside ${VAR:=...} confuses bash's quote scanner (the `'`
    # in "who's" reads as a string-start and bash hunts for a matching one
    # all the way to EOF).
    SAGE_PERSONA_DEFAULT="a curious old-timer of Habitat who has seen it all and likes meeting newcomers"
    : "${HABIBOTS_SAGE_REGION:=context-Downtown_5f}"
    : "${HABIBOTS_SAGE_USER:=SageBot}"
    : "${HABIBOTS_SAGE_PERSONA:=$SAGE_PERSONA_DEFAULT}"
    supervisor -w "${DIR}" -- bots/sage.js \
      -c "${HABIBOTS_SAGE_REGION}" \
      -h "${HABITAT_HOST}" \
      -p "${HABITAT_PORT}" \
      -u "${HABIBOTS_SAGE_USER}" \
      --persona "${HABIBOTS_SAGE_PERSONA}" &
  fi
fi

if [[ "${@}" = *"hatchery"* ]]; then
  echo 'Launching hatchery...'
  supervisor -w "${DIR}" -- bots/hatchery.js \
    -g "${DIR}/assets/hatchery.txt" \
    -c "${HATCHERY_REGION}" \
    -h "${HABITAT_HOST}" \
    -p "${HABITAT_PORT}" \
    -s "${SLACK_TOKEN}" \
    -l "general" \
    -u welcomebot &
fi

sleep 999999999999999
