# Repo-local environment overrides. Copy to `.env` and fill in.
#
#   cp .env.example .env
#   $EDITOR .env
#
# What loads this file:
#   - docker compose: auto-substitutes ${VAR} references in compose files
#     AND every service in every compose file declares this file via
#     `env_file:` (with required:false), so values flow into containers.
#   - habibots/run: sources this file when present so locally-launched
#     bots (outside docker) pick up the same vars.
#   - bridge_v2 host systemd: NOT auto-loaded — production secrets there
#     come from the ansible-rendered /etc/neohabitat/bots.env and
#     /etc/neohabitat/monitoring.env. To use this file for a host-mode
#     bridge, add `EnvironmentFile=-/path/to/repo/.env` to the unit.
#
# Per-service /etc/neohabitat/*.env files (bots.env, monitoring.env)
# still load AFTER this one, so deploy-time secrets always override
# whatever is in here.

# ── Bots ──────────────────────────────────────────────────────────
# SageBot uses Anthropic's API for in-character speech and tool use.
# Without it, sage exits at startup; the other bots keep running.
# ANTHROPIC_API_KEY=sk-ant-...

# Optional model override (defaults to claude-haiku-4-5-20251001).
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Optional persistent-memory backend for sage. Defaults to the docker
# mongo at neohabitatmongo:27017; override only if pointing at an
# external instance.
# HABIBOTS_MONGO_URL=mongodb://neohabitatmongo:27017

# Slack integration for greeter / hatchery / oracle bots. Leave unset
# to disable Slack relays.
# HABIBOTS_SLACK_TOKEN=

# Per-bot region / username overrides — see habibots/run for the full
# list of HABIBOTS_*_REGION and HABIBOTS_*_USER vars each bot honors.

# ── Monitoring ────────────────────────────────────────────────────
# Grafana Cloud OTLP + Loki credentials for the monitoring overlay
# (otel-collector + promtail). On the made these are written to
# /etc/neohabitat/monitoring.env by ansible; for local monitoring
# tests, drop them in here instead.
# GRAFANA_OTLP_ENDPOINT=https://otlp-gateway-prod-us-east-0.grafana.net/otlp
# GRAFANA_OTLP_AUTH=Basic <base64(instance-id:api-key)>
# GRAFANA_LOKI_URL=https://logs-prod-006.grafana.net/loki/api/v1/push
# GRAFANA_LOKI_USERNAME=<loki instance id>
# GRAFANA_LOKI_API_KEY=<api key with MetricsPublisher role>
