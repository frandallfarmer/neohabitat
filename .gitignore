# Repo-local environment overrides. Loaded by docker compose for variable
# substitution AND passed to every container via env_file directives in
# the compose files. Also sourced by habibots/run for host-side dev runs.
# Track .env.example as the documented template; never check in .env itself.
.env

# Claude Code — per-user / transient state.
# Project-shared bits (settings.json, agents/, commands/, skills/, hooks/)
# remain trackable; only personal overrides and runtime files are ignored.
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/projects/
.claude/todos/
.claude/statsig/
.claude/shell-snapshots/
.claude/ide/

# Ansible runtime cache (controller-side fact cache)
ansible/.ansible_cache/

# habiworld test-fixture wire captures (dev-local)

# dev-local wire captures (mounted outside /habibots to avoid supervisor restarts)
/captures/
